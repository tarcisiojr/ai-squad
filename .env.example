# =============================================================================
# AI Squad — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# === Provider: claude-agent-sdk (padrão) ===

# Auth Claude Code CLI (obrigatório)
CLAUDE_CODE_OAUTH_TOKEN=

# === Provider: copilot ===
# Autenticação via 'copilot auth login' (não requer token)
# Opcionalmente, defina GITHUB_TOKEN para autenticar via token
# GITHUB_TOKEN=

# === Provider: agno ===
# Google API Key (obrigatório para provider agno)
# GOOGLE_API_KEY=

# === Messaging: telegram ===

# Token do bot Telegram (obrigatório)
TELEGRAM_TOKEN=

# Chat ID do grupo ou chat privado (obrigatório)
TELEGRAM_CHAT_ID=

# === Messaging: gchat ===
# Requer arquivo credentials.json do Google Cloud Console
# Consulte docs/DEPLOYMENT.md para configuração

# === Opcional ===

# GitHub (para criar PRs e push — necessário se agentes fazem push)
# GITHUB_TOKEN=

# OpenAI API key (para transcrição de voz via Whisper)
# OPENAI_API_KEY=
